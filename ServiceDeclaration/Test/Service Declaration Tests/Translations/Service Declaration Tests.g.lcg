  <Item ItemId=";Codeunit 1004349847 - NamedType 3072794966" ItemType=";Codeunit - GlobalVariable" PsrId="63" InstFlg="true" Leaf="true">
    <Str Cat="Text" CP="DOS">
      <Val><![CDATA[A service transaction type code is not specified]]></Val>
    </Str>
    <Disp Icon="Str" Expand="true" />
    <Cmts>
      <Cmt Name="Dev"><![CDATA[(LookupHint=Codeunit Service Declaration Posting - NamedType TransactionTypeCodeNotSpecifiedInLineErr)]]></Cmt>
    </Cmts>
  </Item>
  <Item ItemId=";Codeunit 695218840 - NamedType 2242053473" ItemType=";Codeunit - GlobalVariable" PsrId="63" InstFlg="true" Leaf="true">
    <Str Cat="Text" CP="DOS">
      <Val><![CDATA[The %1 page is part of the new Service Declaration feature, which is not yet enabled in your Business Central. An administrator can enable the feature on the Feature Management page.]]></Val>
    </Str>
    <Disp Icon="Str" Expand="true" />
    <Cmts>
      <Cmt Name="Dev"><![CDATA[%1 - page caption]D;]A;(LookupHint=Codeunit Service Declaration UI Tests - NamedType FeatureNotEnabledMessageTxt)]]></Cmt>
    </Cmts>
  </Item>
  <Item ItemId=";Codeunit 695218840 - NamedType 253089800" ItemType=";Codeunit - GlobalVariable" PsrId="63" InstFlg="true" Leaf="true">
    <Str Cat="Text" CP="DOS">
      <Val><![CDATA[The service declaration %1 already exists.]]></Val>
    </Str>
    <Disp Icon="Str" Expand="true" />
    <Cmts>
      <Cmt Name="Dev"><![CDATA[%1 = service declaration number.]D;]A;(LookupHint=Codeunit Service Declaration UI Tests - NamedType ServDeclAlreadyExistErr)]]></Cmt>
    </Cmts>
  </Item>
  <Item ItemId=";Codeunit 1019890872 - NamedType 3726067581" ItemType=";Codeunit - GlobalVariable" PsrId="63" InstFlg="true" Leaf="true">
