  <Item ItemId=";Codeunit 4124633478 - NamedType 4007439157" ItemType=";Codeunit - GlobalVariable" PsrId="63" InstFlg="true" Leaf="true">
    <Str Cat="Text" CP="DOS">
      <Val><![CDATA[Do you want to create the Subcontracting Order anyway?]]></Val>
